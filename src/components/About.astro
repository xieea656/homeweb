---
// About — 杂志排版：kicker + 衬线标题 + 非衬线正文 + 等宽标签
import { ABOUT } from "../config";
---

<section id="about" class="px-6 py-32 md:py-40">
  <div class="mx-auto max-w-3xl">
    <!-- Kicker -->
    <p class="kicker mb-4 dark:text-white/50">About</p>

    <!-- 衬线标题 -->
    <h2 class="h2-serif mb-12 text-[clamp(1.6rem,2.8vw,2.4rem)] dark:text-[var(--color-paper)]">
      {ABOUT.title}
    </h2>

    <!-- 正文 (非衬线 body) -->
    <div class="space-y-5">
      {ABOUT.paragraphs.map((p, i) => (
        <p class="anim-in delay-{i === 0 ? '1' : '2'} body-zh text-[clamp(0.9rem,1.15vw,1.05rem)] leading-relaxed text-[var(--color-ink)]/75 dark:text-[var(--color-paper)]/75">
          {p}
        </p>
      ))}
    </div>

    <!-- 分隔线 -->
    <div class="rule my-10 dark:opacity-15"></div>

    <!-- 技能标签 (等宽 mono tags) -->
    <div class="anim-in delay-3 flex flex-wrap gap-3">
      {ABOUT.skills.map((skill) => (
        <span class="tag dark:opacity-55 dark:hover:opacity-90">
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>
