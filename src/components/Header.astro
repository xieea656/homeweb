---
// ============================================================
// Header — 固定导航栏 + 暗色模式切换 + 移动端菜单
// 参考：devportfolio (sticky nav), astro-nano (dark toggle),
//       portfolio-template (keyboard a11y)
// ============================================================
---

<header
  class="fixed top-0 left-0 right-0 z-50 nav-blur
         border-b border-gray-200/60 bg-white/80
         dark:border-gray-800/60 dark:bg-gray-950/80"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4" aria-label="主导航">
    <!-- Logo / 名字 -->
    <a href="#" class="text-lg font-bold tracking-tight text-gray-900 dark:text-white">
      晓黎<span class="text-indigo-600 dark:text-indigo-400">.dev</span>
    </a>

    <!-- 桌面端导航链接 -->
    <div class="hidden items-center gap-8 sm:flex">
      <a href="#about" class="text-sm text-gray-600 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
        关于
      </a>
      <a href="#projects" class="text-sm text-gray-600 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
        项目
      </a>
      <a href="#contact" class="text-sm text-gray-600 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
        联系
      </a>

      <!-- 暗色模式切换 -->
      <button
        id="theme-toggle"
        aria-label="切换暗色模式"
        class="rounded-lg p-2 text-gray-600 transition-colors hover:bg-gray-100
               dark:text-gray-400 dark:hover:bg-gray-800"
        type="button"
      >
        <!-- 太阳图标 (暗色模式下显示) -->
        <svg class="hidden dark:block h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- 月亮图标 (亮色模式下显示) -->
        <svg class="block dark:hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>

    <!-- 移动端：暗色切换 + 汉堡菜单 -->
    <div class="flex items-center gap-2 sm:hidden">
      <button
        id="theme-toggle-mobile"
        aria-label="切换暗色模式"
        class="rounded-lg p-2 text-gray-600 transition-colors hover:bg-gray-100
               dark:text-gray-400 dark:hover:bg-gray-800"
        type="button"
      >
        <svg class="hidden dark:block h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="block dark:hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button
        id="mobile-menu-btn"
        aria-label="菜单"
        aria-expanded="false"
        class="rounded-lg p-2 text-gray-600 transition-colors hover:bg-gray-100
               dark:text-gray-400 dark:hover:bg-gray-800"
        type="button"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- 移动端下拉菜单 -->
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-200/60 bg-white/95 px-6 pb-4 pt-2
           dark:border-gray-800/60 dark:bg-gray-950/95 sm:hidden"
  >
    <a href="#about" class="block rounded-lg px-3 py-2 text-sm text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800">
      关于
    </a>
    <a href="#projects" class="block rounded-lg px-3 py-2 text-sm text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800">
      项目
    </a>
    <a href="#contact" class="block rounded-lg px-3 py-2 text-sm text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800">
      联系
    </a>
  </div>
</header>

<script>
  // 暗色模式切换 (所有按钮同步)
  function setTheme(isDark: boolean) {
    const cls = document.documentElement.classList;
    isDark ? cls.add("dark") : cls.remove("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  function toggleTheme() {
    setTheme(!document.documentElement.classList.contains("dark"));
  }

  document.querySelectorAll("#theme-toggle, #theme-toggle-mobile").forEach((btn) => {
    btn?.addEventListener("click", toggleTheme);
  });

  // 移动端菜单
  const menuBtn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  menuBtn?.addEventListener("click", () => {
    const expanded = menu?.classList.toggle("hidden");
    menuBtn.setAttribute("aria-expanded", String(!expanded));
  });

  // 点击菜单链接后关闭菜单
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menuBtn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
