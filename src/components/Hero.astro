---
// Hero — WebGL 流体背景 + 衬线大字 + 杂志排版
// 参考：guizang-ppt hero page (light bg with subtle overlay)
import { HERO } from "../config";
---

<section
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6"
>
  <!-- WebGL canvas 通过 BaseLayout 的 #bg-canvas 渲染 -->
  <!-- 半透明遮罩让 WebGL 微微透出，保证文字可读 -->
  <div class="absolute inset-0 z-10" style="background:rgba(241,239,234,0.65)"></div>
  <div class="dark absolute inset-0 z-10" style="background:rgba(10,10,11,0.70)"></div>

  <!-- 顶部渐隐：防止 WebGL 图案跑到边缘太明显 -->
  <div class="absolute inset-0 z-10 pointer-events-none"
       style="background:linear-gradient(180deg,rgba(241,239,234,0.45) 0%,rgba(241,239,234,0) 18%,rgba(241,239,234,0) 82%,rgba(241,239,234,0.45) 100%)">
  </div>
  <div class="dark absolute inset-0 z-10 pointer-events-none"
       style="background:linear-gradient(180deg,rgba(10,10,11,0.50) 0%,rgba(10,10,11,0) 18%,rgba(10,10,11,0) 82%,rgba(10,10,11,0.50) 100%)">
  </div>

  <!-- 内容层 -->
  <div class="relative z-20 mx-auto max-w-4xl text-center">
    <!-- Kicker (等宽 mono 标签) -->
    <p class="kicker mb-6 tracking-[0.32em] dark:text-white/50"
       style="animation:fade-up 0.8s ease-out 0.1s both">
      {HERO.greeting}
    </p>

    <!-- 主标题：衬线大字 -->
    <h1 class="display-zh mb-8 text-[clamp(3.5rem,10vw,8rem)] text-[var(--color-ink)] dark:text-[var(--color-paper)]"
        style="animation:fade-up 0.8s ease-out 0.2s both">
      {HERO.name}
    </h1>

    <!-- Lead 段落 (衬线 lead) -->
    <p class="lead mx-auto mb-12 max-w-lg text-[clamp(1rem,1.6vw,1.3rem)] dark:text-white/80"
       style="animation:fade-up 0.8s ease-out 0.35s both">
      {HERO.tagline}
    </p>

    <!-- CTA (极简链接，不用按钮) -->
    <div class="flex flex-wrap items-center justify-center gap-8"
         style="animation:fade-up 0.8s ease-out 0.5s both">
      {HERO.ctas.map((cta, i) => (
        <a
          href={cta.href}
          class={i === 0
            ? "underline-hover mono text-[11px] tracking-[0.28em] uppercase dark:text-white/70"
            : "mono text-[11px] tracking-[0.28em] uppercase opacity-55 hover:opacity-100 transition-opacity dark:text-white/50 dark:hover:text-white/90"
          }
        >
          {cta.text}
          {i === 0 && ' ↓'}
        </a>
      ))}
    </div>
  </div>

  <!-- 暗色模式切换 (右上角) -->
  <button
    onclick="toggleTheme()"
    class="fixed top-6 right-6 z-50 mono text-[10px] tracking-[0.24em] uppercase opacity-40 hover:opacity-80 transition-opacity dark:text-white/50 dark:hover:text-white/80"
    aria-label="切换暗色模式"
    style="animation:fade-up 0.8s ease-out 0.7s both"
  >
    <span class="dark:hidden">Dark</span>
    <span class="hidden dark:inline">Light</span>
  </button>
</section>
