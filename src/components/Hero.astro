---
// ============================================================
// Hero — 首屏大标题
// 参考：Dopefolio (bold hero), simplefolio (greeting + name)
// ============================================================
import { HERO, SITE } from "../config";
---

<section
  id="hero"
  class="flex min-h-[calc(100vh-4rem)] items-center justify-center px-6 pt-20 pb-16"
>
  <div class="mx-auto max-w-3xl text-center">
    <!-- 问候语 — 参考 simplefolio -->
    <p class="animate-fade-in-up delay-100 mb-4 text-sm font-medium uppercase tracking-widest text-indigo-600 dark:text-indigo-400">
      {HERO.greeting}
    </p>

    <!-- 名字 — 大号渐变文字 参考 Dopefolio bold style -->
    <h1 class="animate-fade-in-up delay-200 mb-6 text-5xl font-extrabold tracking-tight sm:text-6xl md:text-7xl">
      <span class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500 bg-clip-text text-transparent dark:from-indigo-400 dark:via-purple-400 dark:to-pink-400">
        {HERO.name}
      </span>
    </h1>

    <!-- 一句话介绍 -->
    <p class="animate-fade-in-up delay-300 mx-auto mb-10 max-w-xl text-lg leading-relaxed text-gray-600 dark:text-gray-400">
      {HERO.tagline}
    </p>

    <!-- CTA 按钮 — 参考 devportfolio 的双按钮布局 -->
    <div class="animate-fade-in-up delay-400 flex flex-wrap items-center justify-center gap-4">
      {HERO.ctas.map((cta, i) => (
        <a
          href={cta.href}
          class={i === 0
            ? "rounded-full bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/25 transition-all hover:bg-indigo-700 hover:shadow-xl hover:shadow-indigo-600/30 hover:-translate-y-0.5 dark:bg-indigo-500 dark:hover:bg-indigo-600"
            : "rounded-full border-2 border-gray-300 px-8 py-3 text-sm font-semibold text-gray-700 transition-all hover:border-indigo-600 hover:text-indigo-600 hover:-translate-y-0.5 dark:border-gray-700 dark:text-gray-300 dark:hover:border-indigo-400 dark:hover:text-indigo-400"
          }
        >
          {cta.text}
          {i === 0 && (
            <svg class="ml-2 inline-block h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
