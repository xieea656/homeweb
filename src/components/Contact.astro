---
// Contact — 极简：kicker + 衬线标题 + 正文 + 邮箱 + 社交图标行
// 零 emoji，全部 Lucide 图标
import { CONTACT } from "../config";
---

<section id="contact" class="px-6 py-32 md:py-40">
  <div class="mx-auto max-w-2xl text-center">
    <!-- Kicker -->
    <p class="kicker mb-4 dark:text-white/50">Contact</p>

    <!-- 衬线标题 -->
    <h2 class="h2-serif mb-12 text-[clamp(1.6rem,2.8vw,2.4rem)] text-[var(--color-ink)] dark:text-[var(--color-paper)]">
      {CONTACT.title}
    </h2>

    <!-- 正文 lead -->
    <p class="lead anim-in delay-1 mx-auto mb-12 max-w-md text-[clamp(0.95rem,1.3vw,1.15rem)] text-[var(--color-ink)]/70 dark:text-[var(--color-paper)]/70">
      {CONTACT.text}
    </p>

    <!-- 邮箱 (大字衬线) -->
    <div class="anim-in delay-2 mb-14">
      <a
        href={`mailto:${CONTACT.email}`}
        class="serif text-[clamp(1.3rem,2vw,1.8rem)] tracking-tight text-[var(--color-ink)] underline-hover dark:text-[var(--color-paper)]"
      >
        {CONTACT.email}
      </a>
    </div>

    <!-- 社交图标行 (Lucide icon CDN) -->
    <div class="anim-in delay-3 flex items-center justify-center gap-8">
      {CONTACT.socials.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-35 hover:opacity-75 transition-opacity dark:opacity-35 dark:hover:opacity-70"
          aria-label={social.name}
          title={social.name}
        >
          <span class="mono text-[10px] tracking-[0.2em] uppercase dark:text-[var(--color-paper)]">
            {social.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
