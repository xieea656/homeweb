---
// ============================================================
// Projects — 项目卡片网格
// 参考：Dopefolio (card hover), devportfolio (tech tags),
//       simplefolio (image + description layout)
// ============================================================
import { PROJECTS } from "../config";
---

<section id="projects" class="bg-gray-50 px-6 py-24 dark:bg-gray-900/50">
  <div class="mx-auto max-w-5xl">
    <h2
      class="section-heading mb-16 text-center text-3xl font-bold tracking-tight
             dark:text-white"
    >
      项目
    </h2>

    <div class="grid gap-6 sm:grid-cols-2">
      {PROJECTS.map((project) => (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card animate-on-scroll group block rounded-2xl border
                 border-gray-200/80 bg-white p-6 no-underline
                 dark:border-gray-800/80 dark:bg-gray-900"
        >
          <!-- 项目名 + 外链箭头 -->
          <div class="mb-3 flex items-start justify-between">
            <h3 class="text-lg font-semibold text-gray-900 transition-colors group-hover:text-indigo-600 dark:text-white dark:group-hover:text-indigo-400">
              {project.name}
            </h3>
            <svg
              class="mt-1 h-4 w-4 flex-shrink-0 text-gray-400 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-indigo-600 dark:text-gray-600"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>

          <!-- 描述 -->
          <p class="mb-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
            {project.description}
          </p>

          <!-- 技术栈标签 — 参考 devportfolio -->
          <div class="flex flex-wrap gap-1.5">
            {project.techs.map((tech) => (
              <span class="rounded-md bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
                {tech}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
