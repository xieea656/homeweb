---
// Projects — 杂志卡片网格：kicker + 衬线标题 + 非衬线描述 + 等宽技术栈
import { PROJECTS } from "../config";
---

<section id="projects" class="px-6 py-24 md:py-32 dark:bg-[var(--color-ink-tint)]" style="background:#e8e5de">
  <div class="mx-auto max-w-5xl">
    <!-- Kicker -->
    <p class="kicker mb-4 dark:text-white/50">Projects</p>

    <!-- 衬线标题 -->
    <h2 class="h2-serif mb-16 text-[clamp(1.6rem,2.8vw,2.4rem)] text-[var(--color-ink)] dark:text-[var(--color-paper)]">
      项目
    </h2>

    <!-- 卡片网格 -->
    <div class="grid gap-8 sm:grid-cols-2">
      {PROJECTS.map((project) => (
        <div class="project-card anim-in group">
          {project.link ? (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="block"
            >
              <!-- 项目名 (衬线) -->
              <h3 class="serif mb-3 text-xl font-semibold tracking-tight text-[var(--color-ink)] dark:text-[var(--color-paper)] group-hover:opacity-70 transition-opacity">
                {project.name}
              </h3>
              <!-- 描述 (非衬线) -->
              <p class="body-zh mb-5 text-sm text-[var(--color-ink)]/65 dark:text-[var(--color-paper)]/65">
                {project.description}
              </p>
            </a>
          ) : (
            <>
              <h3 class="serif mb-3 text-xl font-semibold tracking-tight text-[var(--color-ink)] dark:text-[var(--color-paper)]">
                {project.name}
              </h3>
              <p class="body-zh mb-5 text-sm text-[var(--color-ink)]/65 dark:text-[var(--color-paper)]/65">
                {project.description}
              </p>
            </>
          )}

          <!-- 技术栈 (等宽 mono 极小字) -->
          <div class="flex flex-wrap gap-2">
            {project.techs.map((tech) => (
              <span class="mono text-[9px] tracking-[0.16em] uppercase opacity-40 dark:opacity-35">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
