---
import BaseLayout from "../layouts/BaseLayout.astro";
import { HERO, ABOUT, PROJECTS, CONTACT, FOOTER } from "../config";
import "../styles/global.css";
---

<BaseLayout>
  <!-- ====== 导航 ====== -->
  <nav class="nav">
    <a href="#" class="mono" style="font-size:13px;letter-spacing:0.06em;color:var(--text)">xieea</a>
    <div style="display:flex;gap:2rem;align-items:center">
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
      <a href="https://github.com/xieea656" target="_blank" rel="noopener" class="mono" style="font-size:12px">GitHub</a>
    </div>
  </nav>

  <!-- ====== Hero ====== -->
  <section style="min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:0 2rem;max-width:720px;margin:0 auto">
    <p class="mono fade-in" style="font-size:13px;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:1.5rem">
      {HERO.greeting}
    </p>
    <h1 class="fade-in" style="font-size:clamp(2.8rem,7vw,5rem);font-weight:700;line-height:1.08;letter-spacing:-0.02em;margin-bottom:1.5rem">
      {HERO.name}
    </h1>
    <p class="fade-in" style="font-size:clamp(1rem,2vw,1.2rem);color:var(--text-secondary);line-height:1.6;max-width:560px;margin-bottom:2.5rem">
      {HERO.tagline}
    </p>
    <div class="fade-in" style="display:flex;gap:12px;flex-wrap:wrap">
      <a href="#projects" class="btn btn-primary">View Projects</a>
      <a href="#contact" class="btn btn-outline">Get in Touch</a>
    </div>

    <!-- 社交链接 -->
    <div class="fade-in" style="display:flex;gap:1.5rem;margin-top:3rem">
      {CONTACT.socials.map(s => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" class="link mono" style="font-size:12px">
          {s.name}
        </a>
      ))}
    </div>
  </section>

  <!-- ====== About + Skills ====== -->
  <section id="about" style="padding:6rem 2rem;max-width:720px;margin:0 auto">
    <hr class="hr" style="margin-bottom:4rem" />

    <p class="mono fade-in" style="font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:1rem">
      ABOUT
    </p>

    {ABOUT.paragraphs.map((p, i) => (
      <p class="fade-in" style="font-size:1.05rem;color:var(--text-secondary);line-height:1.7;margin-bottom:1rem;max-width:600px">
        {p}
      </p>
    ))}

    <!-- 技能 -->
    <div class="fade-in" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:2.5rem">
      {ABOUT.skills.map(skill => (
        <span class="skill-tag">{skill}</span>
      ))}
    </div>
  </section>

  <!-- ====== Projects ====== -->
  <section id="projects" style="padding:6rem 2rem;max-width:900px;margin:0 auto">
    <hr class="hr" style="margin-bottom:4rem" />

    <p class="mono fade-in" style="font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:1rem">
      PROJECTS
    </p>
    <h2 class="fade-in" style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:600;margin-bottom:3rem">
      My Work
    </h2>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px">
      {PROJECTS.map((project, i) => (
        <div class="fade-in project-card">
          {project.link ? (
            <a href={project.link} target="_blank" rel="noopener noreferrer" style="text-decoration:none;color:inherit">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                <h3 style="font-size:1.1rem;font-weight:600;margin:0">{project.name}</h3>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4;flex-shrink:0"><path d="M7 17L17 7M7 7h10v10"/></svg>
              </div>
              <p style="font-size:0.9rem;color:var(--text-secondary);line-height:1.55;margin:0 0 14px 0">
                {project.description}
              </p>
            </a>
          ) : (
            <>
              <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:12px">{project.name}</h3>
              <p style="font-size:0.9rem;color:var(--text-secondary);line-height:1.55;margin:0 0 14px 0">
                {project.description}
              </p>
            </>
          )}
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            {project.techs.map(tech => (
              <span class="mono" style="font-size:10px;letter-spacing:0.06em;color:var(--text-muted);padding:3px 8px;background:rgba(250,250,250,0.04);border-radius:4px">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ====== Contact ====== -->
  <section id="contact" style="padding:6rem 2rem 8rem;max-width:720px;margin:0 auto">
    <hr class="hr" style="margin-bottom:4rem" />

    <p class="mono fade-in" style="font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:1rem">
      CONTACT
    </p>
    <h2 class="fade-in" style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:600;margin-bottom:1.5rem">
      Let's talk
    </h2>
    <p class="fade-in" style="color:var(--text-secondary);line-height:1.6;margin-bottom:2.5rem;max-width:480px">
      {CONTACT.text}
    </p>

    <div class="fade-in" style="display:flex;flex-direction:column;gap:1rem">
      <a href={`mailto:${CONTACT.email}`}
         style="font-size:1.2rem;font-weight:500;text-decoration:none;color:var(--text)"
         class="link-underline">
        {CONTACT.email}
      </a>

      <div style="display:flex;gap:2rem;margin-top:0.5rem">
        {CONTACT.socials.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer"
             class="link mono" style="font-size:12px">
            {s.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== Footer ====== -->
  <footer style="padding:2rem;text-align:center;border-top:1px solid var(--border)">
    <p class="mono" style="font-size:11px;color:var(--text-muted);letter-spacing:0.04em">
      {FOOTER.text}
    </p>
  </footer>

  <!-- 滚动入场 -->
  <script>
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.06 });

    document.querySelectorAll(".fade-in").forEach(el => obs.observe(el));
  </script>
</BaseLayout>
